---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Home, AlertTriangle, ArrowLeft } from 'lucide-react';
---

<BaseLayout title="Página no encontrada | Dieta Keto 2026">
  <main class="min-h-screen flex items-center justify-center bg-[#050A15] p-6 relative overflow-hidden selection:bg-orange-500 selection:text-white">
    
    <!-- Background Ambient Glows -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-[800px] h-[600px] bg-red-500/10 rounded-full blur-[150px] pointer-events-none z-0"></div>
    <div class="absolute top-0 right-0 w-96 h-96 bg-orange-500/10 rounded-full blur-[120px] pointer-events-none z-0"></div>

    <div class="max-w-xl w-full text-center relative z-10 reveal-scroll is-visible">
      
      <!-- Premium Glass Box -->
      <div class="bg-[#0A101E]/80 backdrop-blur-2xl rounded-[3rem] p-10 sm:p-14 shadow-2xl border border-white/10 relative overflow-hidden group">
        <div class="absolute inset-0 bg-gradient-to-b from-red-500/5 to-transparent pointer-events-none"></div>
        
        <!-- Animated Error Title Format -->
        <div class="relative mb-2">
            <h1 class="font-poppins text-7xl sm:text-9xl font-black text-transparent bg-clip-text bg-gradient-to-br from-red-500 to-orange-400 drop-shadow-md pb-2">
                404
            </h1>
        </div>
        
        <h2 class="font-poppins text-2xl sm:text-3xl font-bold text-white tracking-tight mb-4 drop-shadow-md">
            Ups... te has perdido
        </h2>
        <p class="text-slate-400 text-sm sm:text-base leading-relaxed mb-10 max-w-md mx-auto">
            La página que estás buscando parece que no existe o ha sido movida. No te preocupes, puedes volver al menú principal para encontrar tu plan Keto.
        </p>

        <div class="pt-2 border-t border-white/10">
          <a 
            href="/" 
            class="inline-flex items-center justify-center gap-3 w-full sm:w-auto px-10 py-5 bg-gradient-to-r from-orange-500 to-red-500 text-white hover:from-orange-400 hover:to-red-400 rounded-xl transition-all font-black text-lg shadow-[0_0_30px_rgba(249,115,22,0.3)] hover:shadow-[0_0_50px_rgba(249,115,22,0.5)] hover:-translate-y-1"
          >
            <ArrowLeft className="w-5 h-5" />
            Volver al Inicio
          </a>
        </div>
      </div>

    </div>
  </main>
</BaseLayout>
