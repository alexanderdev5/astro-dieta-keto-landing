---
import BaseLayout from '../layouts/BaseLayout.astro';
import { CtaStripeButton } from '../components/CtaStripeButton';
import { CountdownTimer } from '../components/react/CountdownTimer';
import { TopHeaderTimer } from '../components/react/TopHeaderTimer';
import { Target, Zap, Brain, ChevronRight, CheckCircle2, Star, Quote, HelpCircle, ShieldCheck, Gift, Play } from 'lucide-react';
import { PRODUCT_CONFIG } from '../config/product';

// Optimizador de Imágenes Nativo (Vía Imgix de Unsplash)
// Ya no necesitas Cloudinary para esto. Unsplash optimiza nativamente a WebP/AVIF.
const getImg = (unsplashId: string, w: number, aspect?: string) => {
  let url = `https://images.unsplash.com/${unsplashId}?auto=format&fm=webp&fit=crop&q=70&w=${w}`;
  if (aspect === '1:1') {
    url += `&h=${w}`; // Fuerza que sea un cuadrado perfecto
  }
  return url;
};

const heroImg = 'photo-1490645935967-10de6ba17061';
---

<BaseLayout>
<div class="fixed bottom-0 left-0 right-0 p-5 z-50 md:hidden bg-[#050A15]/90 backdrop-blur-xl border-t border-slate-800 shadow-[0_-15px_40px_rgba(0,0,0,0.8)]">
    <CtaStripeButton client:idle text="¡Quiero mi Plan Ahora!" className="w-full" />
  </div>

  <main class="relative bg-[#050A15] selection:bg-orange-400 pt-16 overflow-hidden">
    
    <!-- HEADER DE URGENCIA -->
    <TopHeaderTimer client:load />

    <!-- Background Ambient Glows -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-4xl h-[400px] bg-orange-500/10 rounded-full blur-[150px] pointer-events-none z-0"></div>

    <!-- HERO: Beneficio + Tiempo - Esfuerzo -->
    <section class="relative pt-16 pb-24 md:pt-24 md:pb-32 px-4 sm:px-10 lg:px-12 max-w-[1400px] mx-auto z-10 border-b border-white/5">
      <div class="lg:grid lg:grid-cols-12 lg:gap-20 items-center relative z-10">
        <div class="lg:col-span-6 text-center lg:text-left z-10 relative mb-16 lg:mb-0">
          <h1 class="font-poppins text-[2.5rem] leading-[1.1] sm:text-6xl md:text-[4.5rem] font-extrabold text-white tracking-tighter mb-8 drop-shadow-2xl">
            Luce tu cuerpo ideal en <span class="text-transparent bg-clip-text bg-gradient-to-r from-orange-400 to-amber-300 relative inline-block">21 días<svg class="absolute -bottom-3 left-0 w-full h-4 text-orange-500/30" viewBox="0 0 100 10" preserveAspectRatio="none"><path d="M0 5 Q 50 10 100 0" stroke="currentColor" stroke-width="4" fill="none"/></svg></span> <br class="hidden sm:block" />
            sin pasar hambre.
          </h1>

          <p class="mt-6 text-lg sm:text-xl text-slate-300 xl:text-2xl mb-8 font-medium leading-relaxed drop-shadow-sm font-montserrat px-2 sm:px-0">
            Descubre el método de reprogramación metabólica que ha ayudado a +10,000 personas. No es otra dieta restrictiva, es tu nueva <strong class="text-white">libertad</strong>.
          </p>

          <!-- MOVILED VIDEO FACADE (Visible solo en mobile, entre la descripción y el botón) -->
          <div class="block lg:hidden w-full mb-10 relative aspect-video rounded-[2rem] overflow-hidden group cursor-pointer shadow-[0_20px_40px_rgba(0,0,0,0.6)] ring-1 ring-white/10 bg-[#0B1221]" data-ytsrc="https://www.youtube.com/embed/VV23ecSLb2g?autoplay=1" onclick="this.innerHTML = `<iframe width='100%' height='100%' src='${this.dataset.ytsrc}' title='YouTube video player' frameborder='0' allow='accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture;' allowfullscreen class='absolute inset-0'></iframe>`; this.classList.remove('group');">
            <img src="https://i.ytimg.com/vi/VV23ecSLb2g/hqdefault.jpg" loading="eager" fetchpriority="high" alt="Descubre la verdad sobre la Dieta Keto" class="w-full h-full object-cover opacity-70 group-hover:opacity-100 transition-all duration-500" />
            <div class="absolute inset-x-0 bottom-0 top-1/2 bg-gradient-to-t from-[#050A15] via-[#050A15]/60 to-transparent pointer-events-none"></div>
            <div class="absolute bottom-4 left-4 right-4 text-white text-left pointer-events-none">
               <span class="bg-orange-600 text-white text-[9px] font-bold uppercase tracking-wider py-1 px-2.5 rounded-full mb-2 inline-block shadow-lg">NUEVO VIDEO</span>
               <h2 class="font-poppins text-sm leading-tight font-bold text-white drop-shadow-md">Por qué las dietas fallan y cómo hackear tu metabolismo</h2>
            </div>
            <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
              <div class="w-16 h-16 bg-orange-600 rounded-full flex items-center justify-center shadow-[0_0_30px_rgba(234,88,12,0.8)] border-2 border-orange-300/30">
                <Play className="w-6 h-6 text-white ml-1 font-black fill-white" strokeWidth={3} />
              </div>
            </div>
          </div>
          
<div class="flex flex-col sm:flex-row gap-6 justify-center lg:justify-start">
            <CtaStripeButton client:idle text="EMPEZAR MI TRANSFORMACIÓN" className="w-full sm:w-auto min-w-[320px]" />
          </div>
          <div class="mt-10 flex flex-col md:flex-row items-center gap-6 md:gap-8 justify-center lg:justify-start text-slate-400 font-semibold text-sm">
            <div class="flex items-center gap-3 bg-white/5 backdrop-blur-md border border-white/10 px-6 py-3 test-base rounded-full"><CheckCircle2 className="w-6 h-6 text-emerald-400" /> Garantía Total 7 Días</div>
            <div class="flex items-center gap-3 bg-white/5 backdrop-blur-md border border-white/10 px-6 py-3 test-base rounded-full"><Target className="w-6 h-6 text-orange-400" /> Resultados Comprobados</div>
          </div>
        </div>

        <!-- VIDEO SECTION (FACADE PATTERN OPTIMIZADO) -->
        <div class="lg:col-span-6 z-10 relative xl:pl-10">
          <div class="hidden lg:block relative w-full aspect-video rounded-[2.5rem] overflow-hidden group cursor-pointer shadow-[0_30px_60px_rgba(0,0,0,0.8)] ring-2 ring-white/10 bg-[#0B1221]" id="youtube-facade" data-ytsrc="https://www.youtube.com/embed/VV23ecSLb2g?autoplay=1" onclick="this.innerHTML = `<iframe width='100%' height='100%' src='${this.dataset.ytsrc}' title='YouTube video player' frameborder='0' allow='accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture;' allowfullscreen class='absolute inset-0'></iframe>`; this.classList.remove('group');">
            <!-- Usando hqdefault para mayor seguridad de miniatura en youtube -->
            <img src="https://i.ytimg.com/vi/VV23ecSLb2g/hqdefault.jpg" loading="eager" fetchpriority="high" alt="Descubre la verdad sobre la Dieta Keto" class="w-full h-full object-cover opacity-60 group-hover:opacity-80 group-hover:scale-105 transition-all duration-700" />
            
            <div class="absolute inset-x-0 bottom-0 top-1/2 bg-gradient-to-t from-[#050A15] via-[#050A15]/80 to-transparent pointer-events-none"></div>
            
            <div class="absolute bottom-8 left-8 right-8 text-white text-left pointer-events-none">
               <span class="bg-orange-600 text-white text-[10px] sm:text-xs font-bold uppercase tracking-wider py-1.5 px-3 rounded-full mb-3 inline-block shadow-lg">NUEVO VIDEO</span>
               <h2 class="font-poppins text-lg sm:text-xl md:text-2xl font-bold text-white leading-tight drop-shadow-md">Por qué las dietas comunes fallan (y cómo hackear tu metabolismo)</h2>
            </div>
            
            <div class="absolute inset-0 flex items-center justify-center">
              <div class="w-24 h-24 bg-orange-600 rounded-full flex items-center justify-center shadow-[0_0_50px_rgba(234,88,12,0.8)] group-hover:scale-110 group-hover:bg-orange-500 transition-all backdrop-blur-none border-4 border-orange-300/30">
                <Play className="w-10 h-10 text-white ml-1 font-black fill-white" strokeWidth={3} />
              </div>
            </div>
          </div>

          <div class="mt-10 flex items-center justify-center lg:justify-start gap-6 bg-[#0B1221] p-4 rounded-[2rem] border border-white/5 w-fit mx-auto lg:mx-0 pr-8 shadow-xl">
            <div class="flex -space-x-4 pl-2">
               {['photo-1438761681033-6461ffad8d80', 'photo-1500648767791-00dcc994a43e', 'photo-1544005313-94ddf0286df2'].map(id => (
                  <img src={getImg(id, 64, '1:1')} alt="Usuario feliz" class="w-14 h-14 rounded-full border-4 border-[#0B1221] shadow-lg object-cover" />
               ))}
            </div>
            <div class="text-sm font-semibold text-slate-300">
               <div class="flex text-orange-400 mb-1 drop-shadow-[0_0_5px_rgba(251,146,60,0.5)]">
                  {[...Array(5)].map(() => <Star className="w-5 h-5 fill-current" />)}
               </div>
               Más de <span class="text-white">10,000 visitas transformadas</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- AGITACIÓN: El Problema -->
    <section class="py-24 sm:py-32 bg-[#0A101E] px-4 sm:px-10 lg:px-12 relative overflow-hidden border-y border-white/5">
      <div class="absolute top-1/2 left-0 w-96 h-96 bg-red-500/10 rounded-full blur-[150px] pointer-events-none"></div>
      
      <div class="max-w-[1400px] mx-auto relative z-10 lg:grid lg:grid-cols-2 lg:gap-20 items-center">
        <!-- IMAGEN VISUAL LLAMATIVA DEL PROBLEMA -->
        <div class="mb-16 lg:mb-0 relative mx-auto max-w-lg lg:max-w-none group">
          <div class="absolute inset-0 bg-gradient-to-tr from-red-600/20 to-transparent blur-3xl pointer-events-none group-hover:scale-110 transition-transform duration-700"></div>
          <!-- Imagen de Unsplash sobre dietas fallidas / báscula estancada -->
          <img src={getImg('photo-1522845015757-50bce044e5da', 650)} loading="lazy" alt="Frustración con la báscula y dietas" class="rounded-[3rem] shadow-[0_30px_60px_rgba(0,0,0,0.8)] border border-red-500/20 relative z-10 object-cover w-full aspect-square md:aspect-[4/3] grayscale-[20%]" />
          <div class="absolute -bottom-8 -right-4 sm:-right-8 bg-[#050A15]/95 backdrop-blur-xl p-6 rounded-3xl border border-red-500/30 shadow-2xl z-20 flex items-center gap-4 hover:-translate-y-2 transition-transform">
             <div class="bg-red-500/20 p-3 rounded-full"><Zap className="text-red-400 w-8 h-8" /></div>
             <div>
                <p class="text-white font-poppins font-bold text-lg sm:text-xl leading-none mb-1">Metabolismo</p>
                <p class="text-red-400 text-xs sm:text-sm font-bold uppercase tracking-widest">Bloqueado</p>
             </div>
          </div>
        </div>

        <div class="text-center lg:text-left pt-8 reveal-scroll">
          <h2 class="font-poppins text-3xl md:text-5xl lg:text-6xl font-black mb-10 text-white tracking-tight drop-shadow-xl leading-[1.1]">
            ¿Cansado de dietas aburridas que terminan en el <span class="text-transparent bg-clip-text bg-gradient-to-r from-red-400 to-orange-500 block sm:inline mt-2">efecto rebote?</span>
          </h2>
          <div class="space-y-6 text-xl sm:text-2xl text-slate-300 font-light leading-relaxed">
            <p>Sabemos cómo se siente: te mueres de hambre por semanas, logras bajar un poco de peso, pero al primer desliz... <span class="bg-red-500/10 text-red-300 font-bold px-4 py-1.5 rounded-xl inline-block mt-3 border border-red-500/20 shadow-lg">¡pum! Recuperas todo.</span></p>
            <p>Has probado de todo, pero tu cuerpo parece aferrarse a la grasa. Sientes cansancio, antojos incontrolables a las 4 PM y frustración pura.</p>
            <div class="mt-8 bg-white/5 p-6 sm:p-8 rounded-[2rem] border-l-4 border-orange-500 backdrop-blur-sm text-left">
              <p class="text-orange-400 font-semibold text-lg sm:text-xl italic drop-shadow-md mb-6">"¿Y si el problema no fueras tú, sino el sistema engañoso que te vendió la industria para mantenerte a dieta siempre?"</p>
              <div class="flex justify-center lg:justify-start">
                <CtaStripeButton client:visible text="SALIR DEL ESTANCAMIENTO" className="w-full sm:w-auto" />
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- SOLUCIÓN: El Mecanismo Único -->
    <section class="py-32 sm:py-40 bg-[#050A15] px-4 sm:px-10 lg:px-12 relative">
      <div class="max-w-7xl mx-auto">
        <div class="md:grid md:grid-cols-2 md:gap-12 lg:gap-24 items-center">
          <div class="relative mb-20 md:mb-0 group mx-auto max-w-lg md:max-w-none w-full order-1 md:order-2">
            <!-- CLÚSTER CUADRADO BENTO -->
             <div class="relative w-full max-w-md sm:max-w-lg lg:max-w-xl mx-auto aspect-square reveal-scroll">
               <div class="absolute inset-0 bg-gradient-to-br from-orange-500/20 to-transparent blur-3xl group-hover:scale-110 transition-transform duration-700 pointer-events-none"></div>
               
            <!-- CLÚSTER FOTOGRÁFICO CENTRAL (3 Imágenes apiladas como solicitaste originalmente) -->
             <div class="grid grid-cols-2 grid-rows-2 gap-4 sm:gap-6 lg:gap-8 h-full w-full relative z-10 overflow-hidden aspect-square">
                  <!-- Foto 1 (Arriba Izquierda) - Keto 1 Natural -->
                  <img src={getImg('photo-1490818387583-1b5fb1d6d4f8', 400, '1:1')} loading="lazy" alt="Keto 1" class="w-full h-full object-cover rounded-tl-[2rem] sm:rounded-tl-[3.5rem] shadow-xl border border-white/10 hover:scale-[1.03] transition-transform origin-bottom-right" />
                  
                  <!-- Foto 2 (Arriba Derecha) - Keto 1 Zoom/Esquina -->
                  <div class="w-full h-full rounded-tr-[2rem] sm:rounded-tr-[3.5rem] shadow-xl border border-white/10 overflow-hidden relative">
                    <img src={getImg('photo-1490818387583-1b5fb1d6d4f8', 400, '1:1')} loading="lazy" alt="Keto Zoom" class="w-full h-full object-cover scale-[1.5] object-bottom hover:scale-[1.6] transition-transform origin-bottom-left" />
                  </div>
                  
                  <!-- Foto 3 (Abajo Izquierda) - Hero Image -->
                  <img src={getImg('photo-1490645935967-10de6ba17061', 400, '1:1')} loading="lazy" alt="Keto Hero" class="w-full h-full object-cover rounded-bl-[2rem] sm:rounded-bl-[3.5rem] shadow-xl border border-white/10 hover:scale-[1.03] transition-transform origin-top-right brightness-110" />
                  
                  <!-- Foto 4 (Abajo Derecha) - Hero Image Zoomed -->
                  <div class="w-full h-full rounded-br-[2rem] sm:rounded-br-[3.5rem] shadow-xl border border-white/10 overflow-hidden relative">
                    <img src={getImg('photo-1490645935967-10de6ba17061', 350, '1:1')} loading="lazy" alt="Keto Details" class="w-full h-full object-cover scale-[1.8] object-top hover:scale-[1.9] transition-transform origin-top-left brightness-90 saturate-150" />
                  </div>
                  
                  <!-- CÍRCULO CENTRAL FLOTANTE -->
                  <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 bg-orange-600 text-white rounded-full w-24 h-24 sm:w-32 sm:h-32 shadow-[0_15px_40px_rgba(234,88,12,0.8)] border-[6px] border-[#050A15] z-30 flex flex-col items-center justify-center hover:scale-110 transition-transform cursor-default">
                        <span class="font-black font-poppins text-3xl sm:text-5xl leading-none">21</span>
                        <span class="font-bold text-[10px] sm:text-sm uppercase tracking-widest mt-1">Días</span>
                  </div>
              </div>
             </div>
          </div>
          
          <!-- TEXT COLUMN (Order 1 on desktop so it sits on the left) -->
          <div class="relative z-10 order-2 md:order-1 text-center md:text-left reveal-scroll">
            <h2 class="font-poppins text-4xl md:text-5xl font-black text-white mb-10 leading-tight">Por qué nuestro Plan Keto 2026 es el <span class="text-orange-500 relative">último<svg class="absolute -bottom-2 left-0 w-full h-3 text-orange-500/50" viewBox="0 0 100 10" preserveAspectRatio="none"><path d="M0 5 Q 50 10 100 0" stroke="currentColor" stroke-width="4" fill="none"/></svg></span> que intentarás.</h2>
            <p class="text-xl text-slate-300 mb-14 leading-relaxed">
              A diferencia de las modas pasajeras, nuestro sistema de <strong class="text-white">Flexibilidad Metabólica</strong> reprograma tus hormonas. Obligamos a tu cuerpo a usar su propia grasa como combustible primario en lugar de depender del azúcar.
            </p>
            <ul class="space-y-8">
              {[
                { title: 'Derrite la grasa rebelde', desc: 'Vuelve a usar tus jeans favoritos y siente una confianza inquebrantable.', icon: Target, color: 'text-orange-400', bg: 'bg-orange-500/10 border-orange-500/30 shadow-orange-500/20' },
                { title: 'Energía Explosiva 24/7', desc: 'Despídete de la fatiga de la tarde. Tu cerebro y cuerpo amarán las cetonas.', icon: Zap, color: 'text-emerald-400', bg: 'bg-emerald-500/10 border-emerald-500/30 shadow-emerald-500/20' },
                { title: 'Blindaje contra el Rebote', desc: 'Aceleramos tu metabolismo para resultados duraderos e irreversibles.', icon: ShieldCheck, color: 'text-cyan-400', bg: 'bg-cyan-500/10 border-cyan-500/30 shadow-cyan-500/20' }
              ].map((item) => (
                <li class="flex gap-4 sm:gap-6 group items-start p-5 sm:p-6 rounded-3xl sm:rounded-[2rem] bg-white/5 hover:bg-white/10 border border-transparent hover:border-white/10 transition-all duration-300 shadow-xl">
                  <div class={`flex-shrink-0 ${item.bg} p-4 sm:p-5 rounded-2xl sm:rounded-[1.5rem] border backdrop-blur-md shadow-lg group-hover:-translate-y-2 transition-transform duration-300`}>
                    <item.icon className={`w-7 h-7 sm:w-8 sm:h-8 ${item.color}`} />
                  </div>
                  <div class="pt-1">
                    <h3 class="font-poppins font-bold text-white text-2xl mb-3">{item.title}</h3>
                    <p class="text-slate-300 text-lg leading-relaxed">{item.desc}</p>
                  </div>
                </li>
              ))}
            </ul>
            <div class="mt-12 flex justify-center md:justify-start">
               <CtaStripeButton client:visible text="VER EL PLAN COMPLETO" className="w-full sm:w-auto" />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- PRUEBA SOCIAL: Testimonios Ultra-Optimizados -->
    <section class="py-32 sm:py-40 bg-[#0A101E] px-4 sm:px-10 lg:px-12 border-y border-white/5 relative z-10 shadow-[inset_0_20px_50px_rgba(0,0,0,0.5)]">
      <div class="max-w-[1400px] mx-auto">
        <h2 class="font-poppins text-center text-4xl md:text-5xl lg:text-6xl font-black mb-16 text-white drop-shadow-lg leading-tight">Resultados Increíbles de Personas Reales</h2>
        
        <!-- TRANSFORMACIÓN ESTRELLA (CASO DE ÉXITO GRANDE) -->
        <div class="mb-20 bg-white/5 rounded-[2rem] sm:rounded-[3rem] p-6 sm:p-12 border border-white/10 flex flex-col lg:flex-row gap-12 items-center hover:bg-white/10 transition-colors relative z-20">
          <div class="lg:w-1/2 relative group w-full">
            <div class="absolute inset-0 bg-emerald-500/20 blur-2xl rounded-[2rem] pointer-events-none group-hover:bg-emerald-500/30 transition-all"></div>
            <!-- Foto de transformación / persona feliz en forma -->
            <img src={getImg('photo-1518611012118-696072aa579a', 800)} loading="lazy" class="rounded-[2rem] w-full object-cover shadow-2xl relative z-10 border border-white/10 aspect-video lg:aspect-auto h-auto lg:h-[400px]" alt="Transformación destacada" />
            <div class="absolute -bottom-6 -left-4 sm:-left-6 bg-orange-600 text-white px-6 py-3 rounded-2xl font-bold font-poppins shadow-xl border border-orange-300 z-20 transform -rotate-2">CASO DE ÉXITO DEL MES</div>
          </div>
          <div class="lg:w-1/2 text-center lg:text-left z-10 relative">
             <div class="flex gap-2 mb-6 justify-center lg:justify-start">
                {[...Array(5)].map(() => <Star className="w-6 h-6 text-orange-400 fill-orange-400 drop-shadow-[0_0_5px_rgba(249,115,22,0.8)]" />)}
             </div>
             <p class="text-xl sm:text-3xl font-light text-slate-300 italic mb-8 leading-relaxed">"Pensaba que mi genética me condenaba a estar estancada. Este plan no solo reprogramó mi metabolismo, reprogramó mi confianza. Perder 22 kilos sin dejar de comer rico... aún no me lo creo."</p>
             <h3 class="font-poppins text-3xl font-black text-white">Sofía R.</h3>
             <p class="text-emerald-400 font-bold uppercase tracking-widest mt-2">-22 KG EN 4 MESES</p>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-16 md:gap-10 xl:gap-16 mt-16 reveal-scroll">
          {[
             { name: 'María G.', role: 'Madre y Profesional', subtitle: '-15 KG EN 3 MESES', img: 'photo-1438761681033-6461ffad8d80', text: 'Bajé 4 kilos en los primeros 10 días y 15 kg en total. Lo mejor es que no paso hambre y mi energía está por las nubes. ¡Mis jeans de la universidad me quedan perfectos!', rating: 5 },
             { name: 'Carlos R.', role: 'Ingeniero', subtitle: 'SIN ESTANCAMIENTOS', img: 'photo-1500648767791-00dcc994a43e', text: 'He probado todas las dietas existentes. Esta es la única que pude seguir con la oficina. El recetario es oro puro, honestamente como mucho mejor que antes.', rating: 5 },
             { name: 'Elena P.', role: 'Emprendedora', subtitle: 'ADIÓS FATIGA', img: 'photo-1544005313-94ddf0286df2', text: 'Al fin entiendo mi cuerpo. Llevo 12 kilos menos y ya no siento esa necesidad ansiosa de comer dulces a las 4 PM. Esto es una actualización de software para mi cuerpo.', rating: 5 }
          ].map((testi) => (
            <div class="bg-[#050A15]/90 backdrop-blur-xl px-6 py-8 pt-16 sm:p-12 sm:pt-20 rounded-[2rem] sm:rounded-[3rem] shadow-[0_30px_60px_rgba(0,0,0,0.6)] border border-white/10 relative group hover:-translate-y-3 transition-transform duration-500">
              <div class="absolute -top-14 left-1/2 -translate-x-1/2">
                <!-- Fetching real images thanks to DF... cloudname -->
                <img src={getImg(testi.img, 180, '1:1')} loading="lazy" alt={`Testimonio de ${testi.name}`} class="w-28 h-28 rounded-full border-[8px] border-[#0A101E] shadow-2xl object-cover" />
              </div>
              <Quote className="absolute top-8 right-10 w-12 h-12 text-white/5 group-hover:text-white/10 transition-colors" />
              <div class="flex gap-2 mb-8 justify-center">
                {[...Array(testi.rating)].map(() => <Star className="w-5 h-5 text-orange-400 fill-orange-400 drop-shadow-[0_0_5px_rgba(249,115,22,0.8)]" />)}
              </div>
              <p class="text-slate-300 mb-10 relative z-10 leading-relaxed text-center font-medium italic text-lg opacity-90">"{testi.text}"</p>
              <div class="text-center pt-6 border-t border-white/10">
                 <p class="font-poppins font-black text-white text-xl">{testi.name}</p>
                 <p class="text-sm uppercase tracking-[0.2em] font-bold text-orange-500 mt-2">{testi.subtitle}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- OFERTA IRRESISTIBLE -->
