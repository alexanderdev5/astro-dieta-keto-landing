---
import BaseLayout from '../layouts/BaseLayout.astro';
import { CheckCircle2, Mail, ArrowRight, ShieldCheck, Download } from 'lucide-react';
---

<BaseLayout title="¡Compra Exitosa! Bienvenido | Dieta Keto 2026">
  <main class="min-h-screen flex items-center justify-center bg-[#050A15] p-4 sm:p-6 relative overflow-hidden selection:bg-orange-500 selection:text-white">
    
    <!-- Background Ambient Glows -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-[800px] h-[600px] bg-emerald-500/10 rounded-full blur-[150px] pointer-events-none z-0"></div>
    <div class="absolute top-0 right-0 w-96 h-96 bg-orange-500/10 rounded-full blur-[120px] pointer-events-none z-0"></div>

    <div class="max-w-xl w-full text-center relative z-10 reveal-scroll is-visible">
      
      <!-- Premium Glass Box -->
      <div class="bg-[#0A101E]/80 backdrop-blur-2xl rounded-[2.5rem] sm:rounded-[3rem] px-6 py-10 sm:p-14 shadow-2xl border border-white/10 relative overflow-hidden group">
        <div class="absolute inset-0 bg-gradient-to-b from-emerald-500/5 to-transparent pointer-events-none"></div>
        
        <!-- Animated Success Icon Wrapper -->
        <div class="relative w-28 h-28 mx-auto mb-8">
          <div class="absolute inset-0 bg-emerald-500/20 rounded-full blur-xl animate-pulse"></div>
          <div class="bg-gradient-to-tr from-emerald-600 to-emerald-400 w-full h-full rounded-full flex items-center justify-center relative shadow-[0_0_40px_rgba(16,185,129,0.4)] border-4 border-[#050A15]">
            <CheckCircle2 className="w-14 h-14 text-white" strokeWidth={2.5} />
          </div>
        </div>
        
        <h1 class="font-poppins text-4xl sm:text-5xl font-black text-white tracking-tight mb-4 drop-shadow-md">
          ¡Pago Exitoso!
        </h1>
        <p class="font-bold text-emerald-400 uppercase tracking-widest text-sm sm:text-base mb-10">Tu Plan Está Listo</p>
        
        <div class="space-y-6 text-left bg-white/5 p-5 sm:p-6 rounded-2xl sm:rounded-3xl border border-white/5 mb-10">
          <div class="flex items-start gap-4">
            <div class="bg-orange-500/20 p-3 rounded-xl flex-shrink-0">
              <Mail className="w-6 h-6 text-orange-400" />
            </div>
            <div>
              <p class="font-bold text-white text-lg mb-1">Revisa tu correo electrónico</p>
              <p class="text-slate-400 text-sm leading-relaxed">Te acabamos de enviar el acceso total. El remitente es nuestro sistema automatizado de entrega (Resend).</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="bg-blue-500/20 p-3 rounded-xl flex-shrink-0">
              <ShieldCheck className="w-6 h-6 text-blue-400" />
            </div>
            <div>
              <p class="font-bold text-white text-lg mb-1">Carpeta de Spam o Promociones</p>
              <p class="text-slate-400 text-sm leading-relaxed">Si no lo ves en los próximos 2 minutos, revisa tu carpeta de Spam. ¡Guárdanos en tus contactos!</p>
            </div>
          </div>
        </div>

        <div class="pt-2 border-t border-white/10">
          <a 
            href="/" 
            class="inline-flex items-center justify-center gap-2 sm:gap-3 w-full sm:w-auto px-6 py-4 sm:px-10 sm:py-5 bg-white text-black hover:bg-slate-200 rounded-xl transition-all font-black text-base sm:text-lg shadow-xl hover:shadow-2xl hover:-translate-y-1"
          >
            Volver al inicio
            <ArrowRight className="w-5 h-5" />
          </a>
        </div>
      </div>

    </div>
  </main>
</BaseLayout>
